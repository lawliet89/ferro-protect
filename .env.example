# Copy to `.env.local` (gitignored) and fill in for live integration tests.
# Source with `source .env.local` or use direnv, or run `./scripts/live-test`
# which does this for you.

# NVR host (or host:port). Required for live tests.
FERRO_PROTECT_LIVE_HOST=nvr.local

# Preferred: point at a file containing only the API key.
FERRO_PROTECT_LIVE_API_KEY_FILE=$HOME/.config/ferro-protect/api_key

# Alternative (less safe): raw key in the env var.
# FERRO_PROTECT_LIVE_API_KEY=paste-key-here

# Set to any non-empty value to skip TLS verification (self-signed NVRs).
FERRO_PROTECT_LIVE_INSECURE=1
