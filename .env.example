# Copy to `.env.local` (gitignored) and fill in. A single `.env.local`
# drives both the CLI (`cargo run -p ferro-protect-cli -- info`) and the
# live integration tests (`./scripts/live-test`). Source it with
# `set -a; source .env.local; set +a`, or with direnv, or by running
# `./scripts/live-test` (which does the sourcing for you).
#
# Precedence: env vars (set here) override the on-disk config file
# (`~/.config/ferro-protect/config.toml`) but are themselves overridden
# by per-invocation CLI flags. The typical split is: config file for
# interactive use, this `.env.local` for tests and CI. See the
# README's "Configuration" section for the full precedence chain.
# `UNIFI_PROTECT_CONFIG_FILE=<PATH>` selects a different config file.

# NVR host (or host:port) -- HOSTNAME ONLY, no scheme prefix.
# The client always wraps this as https://{host}/proxy/protect/integration.
# Right:   nvr.local            10.0.0.5            10.0.0.5:443
# Wrong:   https://nvr.local    http://10.0.0.5     nvr.local/something
UNIFI_PROTECT_HOST=nvr.local

# Preferred: point at a file containing only the API key.
UNIFI_PROTECT_API_KEY_FILE=$HOME/.config/ferro-protect/api_key

# Alternative (less safe): raw key in the env var.
# UNIFI_PROTECT_API_KEY=paste-key-here

# Set to any non-empty value to skip TLS verification (self-signed NVRs).
UNIFI_PROTECT_INSECURE=1

# Gate for mutating live tests (PATCH, action POSTs, file uploads). Keep
# this commented out (or unset) for routine runs. Set to 1 deliberately,
# preferably against a non-production NVR -- mutating tests can trigger
# physical effects (sirens, chimes, motion notifications).
# UNIFI_PROTECT_ALLOW_MUTATIONS=1

# Log filter for the CLI. Same syntax as env_logger's RUST_LOG. The
# `--log-level <level>` flag overrides this; absent both, RUST_LOG and
# then the literal default `warn` apply. Logs go to stderr.
# UNIFI_PROTECT_LOG=debug
