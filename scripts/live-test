#!/usr/bin/env bash
# Run the ferro-protect live integration test against your NVR.
#
# Loads .env.local (gitignored) if present, then runs the tests gated
# behind #[ignore = "live NVR ..."]. Pass any extra cargo test args after
# the script name; they're forwarded.
#
# See crates/ferro-protect/tests/live.rs for the required environment.

set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if [[ -f .env.local ]]; then
  # shellcheck disable=SC1091
  set -a
  source .env.local
  set +a
fi

if [[ -z "${FERRO_PROTECT_LIVE_HOST:-}" ]]; then
  echo "error: FERRO_PROTECT_LIVE_HOST is unset." >&2
  echo "  Copy .env.example to .env.local and fill it in." >&2
  exit 1
fi

exec cargo test -p ferro-protect --test live -- --ignored --nocapture "$@"
