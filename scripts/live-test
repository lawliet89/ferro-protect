#!/usr/bin/env bash
# Run the ferro-protect live integration tests against your NVR.
#
# Sources .env.local (gitignored) if present, then runs `cargo test --test
# live -- --nocapture`. Live tests auto-skip when the UNIFI_PROTECT_* env
# vars are absent, so this script just plumbs your local config and
# forwards arguments.
#
# Mutating tests are gated separately by UNIFI_PROTECT_ALLOW_MUTATIONS=1.
# See crates/ferro-protect/tests/common/mod.rs and PLAN.md "Testing strategy".
#
# Requires: bash (uses `set -a` / `source`).

set -euo pipefail

REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

if [[ -f .env.local ]]; then
  # shellcheck disable=SC1091
  set -a
  source .env.local
  set +a
fi

if [[ -z "${UNIFI_PROTECT_HOST:-}" ]]; then
  echo "error: UNIFI_PROTECT_HOST is unset." >&2
  echo "  Copy .env.example to .env.local and fill it in." >&2
  exit 1
fi

exec cargo test --features dangerous-tls -p ferro-protect --test live -- --nocapture "$@"
